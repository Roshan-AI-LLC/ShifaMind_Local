# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit it.

# ── HuggingFace ──────────────────────────────────────────────────────────────
# Read-only token sufficient for Bio_ClinicalBERT download.
# Get at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# ── OpenRouter (frontier LLM evaluation) ─────────────────────────────────────
# Single key for GPT-4o, Claude Sonnet 3.7, and Gemini 2.5 Pro.
# Get at: https://openrouter.ai/keys
# Only needed when running: python benchmark/llm_eval.py
OPENROUTER_API_KEY=sk-or-your_key_here
